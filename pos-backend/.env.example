DATABASE_URL="postgresql://user:pass@host:5432/pos_db"
PORT=3000
NODE_ENV=development

JWT_SECRET="change_me"
JWT_EXPIRES_IN="7d"

# Midtrans QRIS Core API
MIDTRANS_SERVER_KEY="YOUR_MIDTRANS_SERVER_KEY"
MIDTRANS_IS_PRODUCTION="false"
# Wajib untuk notifikasi pembayaran QRIS:
# contoh: https://api.yourapp.com/api/payments/webhook/midtrans
MIDTRANS_NOTIFICATION_URL="https://api.yourapp.com/api/payments/webhook/midtrans"
MIDTRANS_QRIS_ACQUIRER="gopay"
MIDTRANS_QRIS_EXPIRY_MINUTES="15"
MIDTRANS_HTTP_MAX_RETRIES="2"
MIDTRANS_HTTP_RETRY_DELAY_MS="400"

# APK Download
# Pilih salah satu:
# 1) Direct URL:
# APK_DOWNLOAD_URL="https://cdn.example.com/apk/pos-kasir.apk"
# 2) Signed URL dari bucket (wajib isi APK_OBJECT_KEY):
APK_BUCKET="pos-apk"
APK_OBJECT_KEY="pos-kasir-latest.apk"
APK_REGION="ap-southeast-1"
APK_ACCESS_KEY_ID="..."
APK_SECRET_ACCESS_KEY="..."
APK_ENDPOINT="https://s3.your-domain.com"
S3_FORCE_PATH_STYLE="true"
APK_URL_TTL_SECONDS="600"
APK_VERSION="1.0.0"
APK_BUILD="100"
APK_CHECKSUM=""
APK_RELEASE_NOTES=""

# Redis (opsional)
REDIS_URL="redis://localhost:6379"

ALLOWED_ORIGINS="http://localhost:3001,http://localhost:5173"
