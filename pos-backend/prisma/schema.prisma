generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/client-node"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── AUTH & USER ────────────────────────────────────────────

model User {
  id           String   @id @default(uuid())
  name         String
  email        String   @unique
  passwordHash String   @map("password_hash")
  role         Role     @default(CASHIER)
  isActive     Boolean  @default(true) @map("is_active")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  branch   Branch? @relation(fields: [branchId], references: [id])
  branchId String? @map("branch_id")

  shifts                Shift[]
  orders                Order[]
  cancelledOrders       Order[]                @relation("OrderCancelledBy")
  auditLogs             AuditLog[]
  orderStatusHistories  OrderStatusHistory[]
  orderCancellations    OrderCancellationLog[]
  shiftSchedules        ShiftSchedule[]        @relation("ShiftScheduleAssignee")
  createdShiftSchedules ShiftSchedule[]        @relation("ShiftScheduleCreator")
  ingredientMovements   IngredientMovement[]   @relation("IngredientMovementCreator")
  purchaseOrdersCreated PurchaseOrder[]        @relation("PurchaseOrderCreator")
  stockOpnamesPerformed StockOpname[]          @relation("StockOpnamePerformer")
  stockOpnamesApproved  StockOpname[]          @relation("StockOpnameApprover")

  @@map("users")
}

enum Role {
  SUPER_ADMIN
  MANAGER
  CASHIER
  WAITER
  KITCHEN
}

enum FeaturePermission {
  DASHBOARD_OVERVIEW
  DASHBOARD_REVENUE_TREND
  DASHBOARD_TOP_PRODUCTS
  DASHBOARD_OCCUPANCY
  DASHBOARD_ACTIVE_ORDERS
  TABLE_MANAGE
  MENU_CATEGORY_MANAGE
  MENU_ITEM_MANAGE
  MENU_VARIANT_MANAGE
  MENU_MODIFIER_MANAGE
  MENU_BUNDLE_MANAGE
  ORDER_MONITOR
  ORDER_HISTORY_VIEW
  ORDER_CANCEL
  INVENTORY_MASTER_MANAGE
  INVENTORY_PURCHASE_MANAGE
  INVENTORY_STOCK_OPNAME
  INVENTORY_REPORT_VIEW
  FINANCE_REPORT_VIEW
  FINANCE_EXPORT_PDF
  SHIFT_RECAP_VIEW
  EMPLOYEE_MANAGE
  EMPLOYEE_SHIFT_MANAGE
  AUDIT_LOG_VIEW
  PROMO_MANAGE
  SYSTEM_SETTINGS_MANAGE
  SYSTEM_BACKUP_MANAGE
}

model RolePermission {
  id         String            @id @default(uuid())
  role       Role
  permission FeaturePermission
  createdAt  DateTime          @default(now()) @map("created_at")

  @@unique([role, permission])
  @@map("role_permissions")
}

// ─── BRANCH ─────────────────────────────────────────────────

model Branch {
  id        String   @id @default(uuid())
  name      String
  address   String?
  phone     String?
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at")

  users                 User[]
  products              Price[]
  variantPrices         VariantPrice[]
  shifts                Shift[]
  orders                Order[]
  inventories           Inventory[]
  stockMovements        StockMovement[]
  tables                DiningTable[]
  ingredientStocks      IngredientStock[]
  ingredientMovements   IngredientMovement[]
  purchaseOrders        PurchaseOrder[]
  stockOpnames          StockOpname[]
  promotions            Promotion[]
  paymentMethodSettings PaymentMethodSetting[]
  printerSettings       PrinterSetting[]
  invoiceSetting        InvoiceSetting?
  businessProfiles      BusinessProfile[]
  shiftSchedules        ShiftSchedule[]
  promotionTargets      PromotionTarget[]

  @@map("branches")
}

// ─── PRODUCT & PRICE ─────────────────────────────────────────

model Category {
  id        String   @id @default(uuid())
  name      String
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at")

  products         Product[]
  promotionTargets PromotionTarget[]

  @@map("categories")
}

model Product {
  id                  String   @id @default(uuid())
  sku                 String   @unique
  name                String
  description         String?
  imageUrl            String?  @map("image_url")
  isActive            Boolean  @default(true) @map("is_active")
  isAvailable         Boolean  @default(true) @map("is_available")
  stockAlertThreshold Int      @default(10) @map("stock_alert_threshold")
  createdAt           DateTime @default(now()) @map("created_at")
  updatedAt           DateTime @updatedAt @map("updated_at")

  category   Category? @relation(fields: [categoryId], references: [id])
  categoryId String?   @map("category_id")

  prices           Price[]
  variants         ProductVariant[]
  orderItems       OrderItem[]
  inventories      Inventory[]
  stockMovements   StockMovement[]
  recipeItems      RecipeItem[]
  bundleItems      BundleItem[]
  modifierGroups   ProductModifierGroup[]
  promotionTargets PromotionTarget[]

  @@map("products")
}

// Harga bisa berbeda per cabang
model Price {
  id        String   @id @default(uuid())
  price     Decimal  @db.Decimal(12, 2)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  product   Product @relation(fields: [productId], references: [id])
  productId String  @map("product_id")

  branch   Branch @relation(fields: [branchId], references: [id])
  branchId String @map("branch_id")

  @@unique([productId, branchId])
  @@map("prices")
}

model ProductVariant {
  id        String   @id @default(uuid())
  name      String
  sku       String?
  sortOrder Int      @default(0) @map("sort_order")
  isDefault Boolean  @default(false) @map("is_default")
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  product   Product @relation(fields: [productId], references: [id])
  productId String  @map("product_id")

  prices      VariantPrice[]
  orderItems  OrderItem[]
  bundleItems BundleItem[]
  recipeItems RecipeItem[]

  @@unique([productId, name])
  @@map("product_variants")
}

model VariantPrice {
  id        String   @id @default(uuid())
  price     Decimal  @db.Decimal(12, 2)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  variant   ProductVariant @relation(fields: [variantId], references: [id])
  variantId String         @map("variant_id")

  branch   Branch @relation(fields: [branchId], references: [id])
  branchId String @map("branch_id")

  @@unique([variantId, branchId])
  @@map("variant_prices")
}

enum ModifierInputType {
  SINGLE
  MULTIPLE
}

model ModifierGroup {
  id         String            @id @default(uuid())
  name       String
  inputType  ModifierInputType @default(MULTIPLE) @map("input_type")
  minSelect  Int               @default(0) @map("min_select")
  maxSelect  Int               @default(0) @map("max_select")
  isRequired Boolean           @default(false) @map("is_required")
  isActive   Boolean           @default(true) @map("is_active")
  createdAt  DateTime          @default(now()) @map("created_at")
  updatedAt  DateTime          @updatedAt @map("updated_at")

  products ProductModifierGroup[]
  options  ModifierOption[]

  @@map("modifier_groups")
}

model ProductModifierGroup {
  id              String @id @default(uuid())
  sortOrder       Int    @default(0) @map("sort_order")
  productId       String @map("product_id")
  modifierGroupId String @map("modifier_group_id")

  product       Product       @relation(fields: [productId], references: [id])
  modifierGroup ModifierGroup @relation(fields: [modifierGroupId], references: [id])

  @@unique([productId, modifierGroupId])
  @@map("product_modifier_groups")
}

model ModifierOption {
  id              String   @id @default(uuid())
  name            String
  priceDelta      Decimal  @default(0) @map("price_delta") @db.Decimal(12, 2)
  sortOrder       Int      @default(0) @map("sort_order")
  isActive        Boolean  @default(true) @map("is_active")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")
  modifierGroupId String   @map("modifier_group_id")

  modifierGroup ModifierGroup @relation(fields: [modifierGroupId], references: [id])

  @@map("modifier_options")
}

model Bundle {
  id          String    @id @default(uuid())
  code        String?   @unique
  name        String
  description String?
  bundlePrice Decimal   @map("bundle_price") @db.Decimal(12, 2)
  isActive    Boolean   @default(true) @map("is_active")
  startAt     DateTime? @map("start_at")
  endAt       DateTime? @map("end_at")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  items            BundleItem[]
  promotionTargets PromotionTarget[]

  @@map("bundles")
}

model BundleItem {
  id        String  @id @default(uuid())
  quantity  Int     @default(1)
  bundleId  String  @map("bundle_id")
  productId String  @map("product_id")
  variantId String? @map("variant_id")

  bundle  Bundle          @relation(fields: [bundleId], references: [id])
  product Product         @relation(fields: [productId], references: [id])
  variant ProductVariant? @relation(fields: [variantId], references: [id])

  @@map("bundle_items")
}

// ─── INVENTORY ───────────────────────────────────────────────

model Inventory {
  id           String   @id @default(uuid())
  quantity     Int      @default(0)
  minimumStock Int      @default(10) @map("minimum_stock")
  updatedAt    DateTime @updatedAt @map("updated_at")

  product   Product @relation(fields: [productId], references: [id])
  productId String  @map("product_id")

  branch   Branch @relation(fields: [branchId], references: [id])
  branchId String @map("branch_id")

  @@unique([productId, branchId])
  @@map("inventories")
}

// Append-only ledger untuk pergerakan stok
model StockMovement {
  id        String       @id @default(uuid())
  type      MovementType
  quantity  Int // positif = masuk, negatif = keluar
  note      String?
  refId     String?      @map("ref_id") // order_id atau PO id
  unitCost  Decimal?     @map("unit_cost") @db.Decimal(12, 2)
  createdBy String?      @map("created_by")
  createdAt DateTime     @default(now()) @map("created_at")

  product   Product @relation(fields: [productId], references: [id])
  productId String  @map("product_id")

  branch   Branch @relation(fields: [branchId], references: [id])
  branchId String @map("branch_id")

  @@map("stock_movements")
}

enum MovementType {
  SALE
  ADJUSTMENT
  TRANSFER_IN
  TRANSFER_OUT
  PURCHASE
  VOID
  RECIPE_USAGE
  STOCK_OPNAME
}

model Unit {
  id        String   @id @default(uuid())
  code      String   @unique
  name      String
  createdAt DateTime @default(now()) @map("created_at")

  ingredients Ingredient[]

  @@map("units")
}

model Ingredient {
  id        String   @id @default(uuid())
  sku       String?  @unique
  name      String
  minStock  Decimal  @default(0) @map("min_stock") @db.Decimal(12, 3)
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  unit   Unit   @relation(fields: [unitId], references: [id])
  unitId String @map("unit_id")

  recipeItems        RecipeItem[]
  stocks             IngredientStock[]
  movements          IngredientMovement[]
  purchaseOrderItems PurchaseOrderItem[]
  stockOpnameItems   StockOpnameItem[]

  @@map("ingredients")
}

model RecipeItem {
  id           String   @id @default(uuid())
  quantity     Decimal  @db.Decimal(12, 3)
  lossFactor   Decimal  @default(0) @map("loss_factor") @db.Decimal(5, 2)
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")
  productId    String   @map("product_id")
  variantId    String?  @map("variant_id")
  ingredientId String   @map("ingredient_id")

  product    Product         @relation(fields: [productId], references: [id])
  variant    ProductVariant? @relation(fields: [variantId], references: [id])
  ingredient Ingredient      @relation(fields: [ingredientId], references: [id])

  @@index([productId, variantId], map: "recipe_items_product_id_variant_id_idx")
  @@index([variantId], map: "recipe_items_variant_id_idx")
  @@map("recipe_items")
}

model IngredientStock {
  id           String   @id @default(uuid())
  quantity     Decimal  @default(0) @db.Decimal(12, 3)
  updatedAt    DateTime @updatedAt @map("updated_at")
  ingredientId String   @map("ingredient_id")
  branchId     String   @map("branch_id")

  ingredient Ingredient @relation(fields: [ingredientId], references: [id])
  branch     Branch     @relation(fields: [branchId], references: [id])

  @@unique([ingredientId, branchId])
  @@map("ingredient_stocks")
}

enum IngredientMovementType {
  PURCHASE
  USAGE
  ADJUSTMENT
  OPNAME
  WASTE
  RETURN
}

model IngredientMovement {
  id           String                 @id @default(uuid())
  type         IngredientMovementType
  quantity     Decimal                @db.Decimal(12, 3)
  unitCost     Decimal?               @map("unit_cost") @db.Decimal(12, 2)
  refId        String?                @map("ref_id")
  note         String?
  createdAt    DateTime               @default(now()) @map("created_at")
  ingredientId String                 @map("ingredient_id")
  branchId     String                 @map("branch_id")
  createdBy    String?                @map("created_by")

  ingredient Ingredient @relation(fields: [ingredientId], references: [id])
  branch     Branch     @relation(fields: [branchId], references: [id])
  creator    User?      @relation("IngredientMovementCreator", fields: [createdBy], references: [id])

  @@index([branchId, createdAt])
  @@map("ingredient_movements")
}

model Supplier {
  id        String   @id @default(uuid())
  name      String
  phone     String?
  email     String?
  address   String?
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  purchaseOrders PurchaseOrder[]

  @@map("suppliers")
}

enum PurchaseOrderStatus {
  DRAFT
  ORDERED
  RECEIVED
  CANCELLED
}

model PurchaseOrder {
  id          String              @id @default(uuid())
  number      String              @unique
  status      PurchaseOrderStatus @default(DRAFT)
  totalAmount Decimal             @default(0) @map("total_amount") @db.Decimal(12, 2)
  orderedAt   DateTime?           @map("ordered_at")
  receivedAt  DateTime?           @map("received_at")
  note        String?
  createdAt   DateTime            @default(now()) @map("created_at")
  updatedAt   DateTime            @updatedAt @map("updated_at")
  branchId    String              @map("branch_id")
  supplierId  String?             @map("supplier_id")
  createdBy   String?             @map("created_by")

  branch   Branch    @relation(fields: [branchId], references: [id])
  supplier Supplier? @relation(fields: [supplierId], references: [id])
  creator  User?     @relation("PurchaseOrderCreator", fields: [createdBy], references: [id])

  items PurchaseOrderItem[]

  @@map("purchase_orders")
}

model PurchaseOrderItem {
  id              String  @id @default(uuid())
  qtyOrdered      Decimal @map("qty_ordered") @db.Decimal(12, 3)
  qtyReceived     Decimal @default(0) @map("qty_received") @db.Decimal(12, 3)
  unitCost        Decimal @map("unit_cost") @db.Decimal(12, 2)
  subtotal        Decimal @db.Decimal(12, 2)
  purchaseOrderId String  @map("purchase_order_id")
  ingredientId    String  @map("ingredient_id")

  purchaseOrder PurchaseOrder @relation(fields: [purchaseOrderId], references: [id])
  ingredient    Ingredient    @relation(fields: [ingredientId], references: [id])

  @@map("purchase_order_items")
}

enum StockOpnameStatus {
  DRAFT
  SUBMITTED
  APPROVED
}

model StockOpname {
  id          String            @id @default(uuid())
  number      String            @unique
  status      StockOpnameStatus @default(DRAFT)
  note        String?
  opnameAt    DateTime          @default(now()) @map("opname_at")
  approvedAt  DateTime?         @map("approved_at")
  createdAt   DateTime          @default(now()) @map("created_at")
  updatedAt   DateTime          @updatedAt @map("updated_at")
  branchId    String            @map("branch_id")
  performedBy String?           @map("performed_by")
  approvedBy  String?           @map("approved_by")

  branch    Branch            @relation(fields: [branchId], references: [id])
  performer User?             @relation("StockOpnamePerformer", fields: [performedBy], references: [id])
  approver  User?             @relation("StockOpnameApprover", fields: [approvedBy], references: [id])
  items     StockOpnameItem[]

  @@map("stock_opnames")
}

model StockOpnameItem {
  id            String  @id @default(uuid())
  systemQty     Decimal @map("system_qty") @db.Decimal(12, 3)
  actualQty     Decimal @map("actual_qty") @db.Decimal(12, 3)
  differenceQty Decimal @map("difference_qty") @db.Decimal(12, 3)
  note          String?
  stockOpnameId String  @map("stock_opname_id")
  ingredientId  String  @map("ingredient_id")

  stockOpname StockOpname @relation(fields: [stockOpnameId], references: [id])
  ingredient  Ingredient  @relation(fields: [ingredientId], references: [id])

  @@map("stock_opname_items")
}

// ─── SHIFT ───────────────────────────────────────────────────

model Shift {
  id          String      @id @default(uuid())
  openedAt    DateTime    @default(now()) @map("opened_at")
  closedAt    DateTime?   @map("closed_at")
  openingCash Decimal     @map("opening_cash") @db.Decimal(12, 2)
  closingCash Decimal?    @map("closing_cash") @db.Decimal(12, 2)
  status      ShiftStatus @default(OPEN)

  user   User   @relation(fields: [userId], references: [id])
  userId String @map("user_id")

  branch   Branch @relation(fields: [branchId], references: [id])
  branchId String @map("branch_id")

  orders        Order[]
  cashMovements CashMovement[]

  @@map("shifts")
}

enum ShiftStatus {
  OPEN
  CLOSED
}

enum ScheduleStatus {
  PLANNED
  CONFIRMED
  CANCELLED
}

model ShiftSchedule {
  id        String         @id @default(uuid())
  startAt   DateTime       @map("start_at")
  endAt     DateTime       @map("end_at")
  status    ScheduleStatus @default(PLANNED)
  note      String?
  createdAt DateTime       @default(now()) @map("created_at")
  updatedAt DateTime       @updatedAt @map("updated_at")

  userId    String  @map("user_id")
  branchId  String  @map("branch_id")
  createdBy String? @map("created_by")

  user    User   @relation("ShiftScheduleAssignee", fields: [userId], references: [id])
  branch  Branch @relation(fields: [branchId], references: [id])
  creator User?  @relation("ShiftScheduleCreator", fields: [createdBy], references: [id])

  @@index([branchId, startAt, endAt])
  @@map("shift_schedules")
}

enum TableStatus {
  AVAILABLE
  OCCUPIED
  RESERVED
  OUT_OF_SERVICE
}

model DiningTable {
  id        String      @id @default(uuid())
  name      String
  status    TableStatus @default(AVAILABLE)
  isActive  Boolean     @default(true) @map("is_active")
  createdAt DateTime    @default(now()) @map("created_at")
  updatedAt DateTime    @updatedAt @map("updated_at")
  branchId  String      @map("branch_id")

  branch Branch  @relation(fields: [branchId], references: [id])
  orders Order[]

  @@unique([branchId, name])
  @@map("dining_tables")
}

// ─── ORDER ───────────────────────────────────────────────────

model Order {
  id                String                 @id @default(uuid())
  receiptNumber     String                 @unique @map("receipt_number")
  clientOrderId     String?                @unique @map("client_order_id") // untuk idempotency offline
  status            OrderStatus            @default(DRAFT)
  fulfillmentStatus OrderFulfillmentStatus @default(PENDING) @map("fulfillment_status")
  subtotal          Decimal                @db.Decimal(12, 2)
  discountAmount    Decimal                @default(0) @map("discount_amount") @db.Decimal(12, 2)
  taxAmount         Decimal                @default(0) @map("tax_amount") @db.Decimal(12, 2)
  serviceCharge     Decimal                @default(0) @map("service_charge") @db.Decimal(12, 2)
  hppAmount         Decimal                @default(0) @map("hpp_amount") @db.Decimal(12, 2)
  totalAmount       Decimal                @map("total_amount") @db.Decimal(12, 2)
  note              String?
  tableNumber       String?                @map("table_number") // nomor meja / take away
  orderType         OrderType              @default(DINE_IN) @map("order_type")
  cancelReason      String?                @map("cancel_reason")
  cancelledAt       DateTime?              @map("cancelled_at")
  cancelledBy       String?                @map("cancelled_by")
  createdAt         DateTime               @default(now()) @map("created_at")
  updatedAt         DateTime               @updatedAt @map("updated_at")

  cashier   User   @relation(fields: [cashierId], references: [id])
  cashierId String @map("cashier_id")

  branch   Branch @relation(fields: [branchId], references: [id])
  branchId String @map("branch_id")

  shift   Shift?  @relation(fields: [shiftId], references: [id])
  shiftId String? @map("shift_id")

  table   DiningTable? @relation(fields: [tableId], references: [id])
  tableId String?      @map("table_id")

  cancelledByUser  User?                  @relation("OrderCancelledBy", fields: [cancelledBy], references: [id])
  items            OrderItem[]
  payments         Payment[]
  statusHistories  OrderStatusHistory[]
  cancellationLogs OrderCancellationLog[]
  refunds          Refund[]

  @@map("orders")
}

enum OrderType {
  DINE_IN
  TAKE_AWAY
}

enum OrderStatus {
  DRAFT
  PENDING_PAYMENT
  PAID
  CANCELLED
  VOID
}

enum OrderFulfillmentStatus {
  PENDING
  IN_PROGRESS
  READY
  SERVED
  CANCELLED
}

model OrderItem {
  id               String  @id @default(uuid())
  quantity         Int
  unitPrice        Decimal @map("unit_price") @db.Decimal(12, 2)
  discount         Decimal @default(0) @db.Decimal(12, 2)
  subtotal         Decimal @db.Decimal(12, 2)
  hppSubtotal      Decimal @default(0) @map("hpp_subtotal") @db.Decimal(12, 2)
  orderBatchNumber Int     @default(1) @map("order_batch_number")
  kitchenPrintedAt DateTime? @map("kitchen_printed_at")
  modifierSnapshot Json?   @map("modifier_snapshot")
  note             String? // catatan item: "pedas", "tanpa bawang", dll

  order   Order  @relation(fields: [orderId], references: [id])
  orderId String @map("order_id")

  product   Product         @relation(fields: [productId], references: [id])
  productId String          @map("product_id")
  variant   ProductVariant? @relation(fields: [variantId], references: [id])
  variantId String?         @map("variant_id")

  @@map("order_items")
}

model OrderStatusHistory {
  id         String       @id @default(uuid())
  fromStatus OrderStatus? @map("from_status")
  toStatus   OrderStatus  @map("to_status")
  note       String?
  changedAt  DateTime     @default(now()) @map("changed_at")
  orderId    String       @map("order_id")
  changedBy  String?      @map("changed_by")

  order Order @relation(fields: [orderId], references: [id])
  user  User? @relation(fields: [changedBy], references: [id])

  @@index([orderId, changedAt])
  @@map("order_status_histories")
}

model OrderCancellationLog {
  id             String      @id @default(uuid())
  reason         String
  note           String?
  previousStatus OrderStatus @map("previous_status")
  cancelledAt    DateTime    @default(now()) @map("cancelled_at")
  orderId        String      @map("order_id")
  cancelledBy    String?     @map("cancelled_by")

  order Order @relation(fields: [orderId], references: [id])
  user  User? @relation(fields: [cancelledBy], references: [id])

  @@index([orderId, cancelledAt])
  @@map("order_cancellation_logs")
}

// ─── PAYMENT ─────────────────────────────────────────────────

model Payment {
  id             String        @id @default(uuid())
  method         PaymentMethod
  status         PaymentStatus @default(INITIATED)
  amount         Decimal       @db.Decimal(12, 2)
  idempotencyKey String        @unique @map("idempotency_key")
  gatewayRef     String?       @map("gateway_ref") // referensi transaksi gateway
  qrPayload      String?       @map("qr_payload") // untuk QRIS
  expiredAt      DateTime?     @map("expired_at")
  paidAt         DateTime?     @map("paid_at")
  meta           Json? // data tambahan per method / provider
  refunds        Refund[]
  createdAt      DateTime      @default(now()) @map("created_at")
  updatedAt      DateTime      @updatedAt @map("updated_at")

  order   Order  @relation(fields: [orderId], references: [id])
  orderId String @map("order_id")

  attempts PaymentAttempt[]
  events   PaymentEvent[]

  @@map("payments")
}

enum PaymentMethod {
  CASH
  QRIS
  VIRTUAL_ACCOUNT
  EWALLET
  CARD
}

enum PaymentStatus {
  INITIATED
  PENDING
  SUCCESS
  FAILED
  EXPIRED
  REFUNDED
}

// Append-only log tiap webhook / event dari gateway
model PaymentEvent {
  id          String   @id @default(uuid())
  eventType   String   @map("event_type")
  provider    String
  rawPayload  Json     @map("raw_payload")
  processedAt DateTime @default(now()) @map("processed_at")

  payment   Payment @relation(fields: [paymentId], references: [id])
  paymentId String  @map("payment_id")

  @@map("payment_events")
}

model PaymentAttempt {
  id        String   @id @default(uuid())
  status    String
  note      String?
  createdAt DateTime @default(now()) @map("created_at")

  payment   Payment @relation(fields: [paymentId], references: [id])
  paymentId String  @map("payment_id")

  @@map("payment_attempts")
}

// ─── AUDIT LOG ───────────────────────────────────────────────

model AuditLog {
  id        String   @id @default(uuid())
  action    String
  entity    String
  entityId  String   @map("entity_id")
  oldData   Json?    @map("old_data")
  newData   Json?    @map("new_data")
  ip        String?
  createdAt DateTime @default(now()) @map("created_at")

  user   User?   @relation(fields: [userId], references: [id])
  userId String? @map("user_id")

  @@map("audit_logs")
}

// ─── CASH MOVEMENT ───────────────────────────────────────────

model CashMovement {
  id        String           @id @default(uuid())
  type      CashMovementType
  amount    Decimal          @db.Decimal(12, 2)
  note      String?
  createdAt DateTime         @default(now()) @map("created_at")

  shift   Shift  @relation(fields: [shiftId], references: [id])
  shiftId String @map("shift_id")

  recordedBy String @map("recorded_by")

  @@map("cash_movements")
}

enum CashMovementType {
  OPENING
  CLOSING
  CASH_IN
  CASH_OUT
}

// ─── REFUND ──────────────────────────────────────────────────

model Refund {
  id          String       @id @default(uuid())
  paymentId   String       @map("payment_id")
  orderId     String       @map("order_id")
  amount      Decimal      @db.Decimal(12, 2)
  reason      String
  status      RefundStatus @default(PENDING)
  gatewayRef  String?      @map("gateway_ref") // referensi refund gateway
  requestedBy String       @map("requested_by") // userId
  processedAt DateTime?    @map("processed_at")
  failReason  String?      @map("fail_reason")
  createdAt   DateTime     @default(now()) @map("created_at")
  updatedAt   DateTime     @updatedAt @map("updated_at")

  payment Payment @relation(fields: [paymentId], references: [id])
  order   Order   @relation(fields: [orderId], references: [id])

  @@map("refunds")
}

enum RefundStatus {
  PENDING
  PROCESSING
  SUCCESS
  FAILED
}

enum PromotionType {
  PERCENTAGE
  NOMINAL
  HAPPY_HOUR
  BUNDLE
  BUY_ONE_GET_ONE
}

enum PromotionValueType {
  PERCENTAGE
  NOMINAL
}

enum PromotionTargetType {
  ORDER
  PRODUCT
  CATEGORY
  BUNDLE
}

model Promotion {
  id          String              @id @default(uuid())
  code        String?             @unique
  name        String
  description String?
  type        PromotionType
  valueType   PromotionValueType? @map("value_type")
  value       Decimal?            @db.Decimal(12, 2)
  buyQty      Int?                @map("buy_qty")
  getQty      Int?                @map("get_qty")
  startAt     DateTime            @map("start_at")
  endAt       DateTime            @map("end_at")
  isActive    Boolean             @default(true) @map("is_active")
  createdAt   DateTime            @default(now()) @map("created_at")
  updatedAt   DateTime            @updatedAt @map("updated_at")
  branchId    String?             @map("branch_id")

  branch  Branch?           @relation(fields: [branchId], references: [id])
  targets PromotionTarget[]

  @@index([startAt, endAt, isActive])
  @@map("promotions")
}

model PromotionTarget {
  id          String              @id @default(uuid())
  targetType  PromotionTargetType @map("target_type")
  targetId    String              @map("target_id")
  minQty      Int                 @default(1) @map("min_qty")
  branchId    String?             @map("branch_id")
  promotionId String              @map("promotion_id")

  productId  String? @map("product_id")
  categoryId String? @map("category_id")
  bundleId   String? @map("bundle_id")

  promotion Promotion @relation(fields: [promotionId], references: [id])
  branch    Branch?   @relation(fields: [branchId], references: [id])
  product   Product?  @relation(fields: [productId], references: [id])
  category  Category? @relation(fields: [categoryId], references: [id])
  bundle    Bundle?   @relation(fields: [bundleId], references: [id])

  @@map("promotion_targets")
}

model BusinessProfile {
  id                String   @id @default(uuid())
  name              String
  logoUrl           String?  @map("logo_url")
  address           String?
  phone             String?
  email             String?
  taxNumber         String?  @map("tax_number")
  taxRate           Decimal  @default(0) @map("tax_rate") @db.Decimal(5, 2)
  serviceChargeRate Decimal  @default(0) @map("service_charge_rate") @db.Decimal(5, 2)
  currency          String   @default("IDR")
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")
  branchId          String?  @map("branch_id")

  branch Branch? @relation(fields: [branchId], references: [id])

  @@map("business_profiles")
}

model PaymentMethodSetting {
  id            String        @id @default(uuid())
  method        PaymentMethod
  isActive      Boolean       @default(true) @map("is_active")
  configuration Json?
  createdAt     DateTime      @default(now()) @map("created_at")
  updatedAt     DateTime      @updatedAt @map("updated_at")
  branchId      String?       @map("branch_id")

  branch Branch? @relation(fields: [branchId], references: [id])

  @@unique([branchId, method])
  @@map("payment_method_settings")
}

model PrinterSetting {
  id             String   @id @default(uuid())
  name           String
  printerType    String   @map("printer_type")
  connectionInfo Json     @map("connection_info")
  isActive       Boolean  @default(true) @map("is_active")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")
  branchId       String   @map("branch_id")

  branch Branch @relation(fields: [branchId], references: [id])

  @@map("printer_settings")
}

model InvoiceSetting {
  id               String   @id @default(uuid())
  headerText       String?  @map("header_text")
  footerText       String?  @map("footer_text")
  showLogo         Boolean  @default(true) @map("show_logo")
  showTaxBreakdown Boolean  @default(true) @map("show_tax_breakdown")
  prefix           String?  @map("prefix")
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")
  branchId         String   @unique @map("branch_id")

  branch Branch @relation(fields: [branchId], references: [id])

  @@map("invoice_settings")
}

model BackupLog {
  id          String    @id @default(uuid())
  status      String
  filePath    String?   @map("file_path")
  sizeBytes   BigInt?   @map("size_bytes")
  startedAt   DateTime  @default(now()) @map("started_at")
  completedAt DateTime? @map("completed_at")
  triggeredBy String?   @map("triggered_by")

  @@map("backup_logs")
}
